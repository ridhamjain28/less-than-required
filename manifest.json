{
    "manifest_version": 3,
    "name": "Less Than Required",
    "version": "1.0",
    "description": "Automatically compresses files to meet upload size limits.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "src/popup.html",
        "default_title": "Less Than Required"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "all_frames": true,
            "css": [
                "src/content_styles.css"
            ],
            "js": [
                "src/utils/pdf-lib.min.js",
                "src/utils/compressor.js",
                "src/content_script.js"
            ],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "src/background.js"
    }
}